{
  "name": "dom-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/dom-utils/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project dom-utils --web",
  "targets": {
    "build": {
      "executor": "@thalesrc/nx-utils:ts-builder-v2",
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfigPath": "libs/dom-utils/tsconfig.lib.json",
        "outputPath": "dist/libs/dom-utils",
        "name": "dom-utils",
        "formats": {
          "esm": { "perFile": true, "flat": true },
          "cjs": { "perFile": true, "flat": false },
          "types": { "dts": true, "dcts": true }
        }
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "libs/dom-utils/vite.config.ts",
        "passWithNoTests": true
      }
    },
    "test/coverage": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "libs/dom-utils/vite.config.ts",
        "passWithNoTests": true,
        "coverage": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run dom-utils:publish/prepare",
          "nx run dom-utils:publish/to-npm"
        ],
        "parallel": false
      }
    },
    "publish/prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run dom-utils:build",
          "nx run dom-utils:publish/prepare/copy",
          "nx run dom-utils:publish/prepare/fill-package-json --packageVersion=$PACKAGE_VERSION"
        ],
        "parallel": false
      }
    },
    "publish/prepare/copy": {
      "executor": "@thalesrc/nx-utils:copy",
      "options": {
        "input": ["libs/dom-utils/README.md", "libs/dom-utils/LICENSE"],
        "output": "dist/libs/dom-utils"
      }
    },
    "publish/prepare/fill-package-json": {
      "executor": "@thalesrc/nx-utils:fill-package-json-v2",
      "options": {
        "outputPath": "dist/libs/dom-utils",
        "populateExports": {}
      }
    },
    "publish/to-npm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/libs/dom-utils"
      }
    }
  }
}
