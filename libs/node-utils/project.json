{
  "name": "node-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/node-utils/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@thalesrc/nx-utils:ts-builder-v2",
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfigPath": "libs/node-utils/tsconfig.lib.json",
        "outputPath": "dist/libs/node-utils",
        "name": "node-utils",
        "formats": {
          "esm": { "perFile": true, "flat": true },
          "cjs": { "perFile": true, "flat": false },
          "types": { "dts": true, "dcts": true }
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/node-utils/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run node-utils:publish/prepare --packageVersion=$PACKAGE_VERSION",
          "nx run node-utils:publish/to-npm"
        ],
        "parallel": false
      }
    },
    "publish/prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run node-utils:build",
          "nx run node-utils:publish/prepare/copy",
          "nx run node-utils:publish/prepare/fill-package-json --packageVersion=$PACKAGE_VERSION"
        ],
        "parallel": false
      }
    },
    "publish/prepare/copy": {
      "executor": "@thalesrc/nx-utils:copy",
      "options": {
        "input": ["libs/node-utils/README.md", "libs/node-utils/LICENSE", "libs/node-utils/cli.cjs"],
        "output": "dist/libs/node-utils"
      }
    },
    "publish/prepare/fill-package-json": {
      "executor": "@thalesrc/nx-utils:fill-package-json-v2",
      "options": {
        "outputPath": "dist/libs/node-utils",
        "populateExports": {}
      }
    },
    "publish/to-npm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/libs/node-utils"
      }
    }
  }
}
