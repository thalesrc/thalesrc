{
  "name": "paintlet",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/paintlet/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@thalesrc/nx-utils:ts-builder-v2",
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfigPath": "libs/paintlet/tsconfig.lib.json",
        "outputPath": "dist/libs/paintlet",
        "name": "paintlet",
        "formats": {
          "esm": { "perFile": true, "flat": true },
          "cjs": { "perFile": true, "flat": false },
          "types": { "dts": true, "dcts": true }
        }
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run paintlet:publish/prepare",
          "nx run paintlet:publish/to-npm"
        ],
        "parallel": false
      }
    },
    "publish/prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run paintlet:build",
          "nx run paintlet:publish/prepare/copy",
          "nx run paintlet:publish/prepare/fill-package-json --packageVersion=$PACKAGE_VERSION"
        ],
        "parallel": false
      }
    },
    "publish/prepare/copy": {
      "executor": "@thalesrc/nx-utils:copy",
      "options": {
        "input": ["libs/paintlet/README.md", "libs/paintlet/LICENSE"],
        "output": "dist/libs/paintlet"
      }
    },
    "publish/prepare/fill-package-json": {
      "executor": "@thalesrc/nx-utils:fill-package-json-v2",
      "options": {
        "outputPath": "dist/libs/paintlet",
        "populateExports": {}
      }
    },
    "publish/to-npm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/libs/paintlet"
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "libs/paintlet/.storybook",
        "port": 6006,
        "ci": true,
        "quiet": false,
        "uiFramework": "@storybook/web-components",
        "buildTarget": "paintlet:build"
      }
    }
  }
}
