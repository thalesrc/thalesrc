{
  "name": "elements",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/elements/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@thalesrc/nx-utils:ts-builder-v2",
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfigPath": "libs/elements/tsconfig.lib.json",
        "outputPath": "dist/libs/elements",
        "name": "elements",
        "entry": {
          "index": "src/index.ts",
          "router/index": "src/router/index.ts",
          "drag-drop/index": "src/drag-drop/index.ts",
          "icon/index": "src/icon/index.ts"
        },
        "formats": {
          "esm": { "perFile": true, "flat": true },
          "cjs": { "perFile": true, "flat": false },
          "iife": {
            "name": "TelperionElements",
            "fileName": "elements",
            "minify": true,
            "entries": {
              "icon/index": {},
              "drag-drop/index": {},
              "router/index": {}
            }
          },
          "types": { "dts": true, "dcts": true }
        }
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run elements:publish/prepare",
          "nx run elements:publish/to-npm"
        ],
        "parallel": false
      }
    },
    "publish/prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run elements:build",
          "nx run elements:publish/prepare/copy",
          "nx run elements:publish/prepare/fill-package-json --packageVersion=$PACKAGE_VERSION"
        ],
        "parallel": false
      }
    },
    "publish/prepare/copy": {
      "executor": "@thalesrc/nx-utils:copy",
      "options": {
        "input": [
          "libs/elements/README.md",
          "libs/elements/LICENSE",
          {
            "path": "libs/elements/src/icon/material-symbols.css",
            "output": "dist/libs/elements/icon"
          }
        ],
        "output": "dist/libs/elements"
      }
    },
    "publish/prepare/fill-package-json": {
      "executor": "@thalesrc/nx-utils:fill-package-json-v2",
      "options": {
        "outputPath": "dist/libs/elements",
        "cdn": "iife/elements.js",
        "sideEffects": ["**/*-element.js", "**/*-element.cjs", "**/*.css"],
        "populateExports": {
          "exports": ["types", "node", "import", "require", "script", "default"]
        }
      }
    },
    "publish/to-npm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/libs/elements"
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "libs/elements/.storybook",
        "port": 6006,
        "ci": true,
        "quiet": false,
        "uiFramework": "@storybook/web-components",
        "buildTarget": "elements:build"
      }
    }
  }
}
